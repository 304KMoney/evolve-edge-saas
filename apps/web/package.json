{
  "name": "@evolve-edge/web",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "integration:status": "tsx scripts/integration-status.ts",
    "preflight:first-customer:env": "tsx --require ./scripts/shims/server-only.js scripts/first-customer-env-status.ts",
    "preflight:first-customer": "tsx --require ./scripts/shims/server-only.js scripts/first-customer-preflight.ts",
    "load:test:ai": "tsx scripts/load-test-ai-execution.ts",
    "test": "tsx scripts/run-tests.ts",
    "test:ai": "tsx test/ai-workflow-node-regression.test.ts && tsx test/ai-evals.test.ts && tsx test/ai-feedback.test.ts",
    "ai:eval": "tsx src/server/ai/evals/run-evals.ts",
    "ai:eval:live": "tsx src/server/ai/evals/run-evals.ts --live",
    "env:parity:audit": "tsx scripts/env-parity-audit.ts"
  },
  "dependencies": {
    "@evolve-edge/db": "workspace:*",
    "@langchain/core": "^0.3.66",
    "@langchain/langgraph": "^0.2.74",
    "@langchain/openai": "^0.4.0",
    "@sentry/nextjs": "^9.14.0",
    "@upstash/redis": "^1.37.0",
    "lucide-react": "^0.511.0",
    "next": "^15.2.4",
    "openai": "^5.10.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.12.2",
    "server-only": "^0.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@prisma/nextjs-monorepo-workaround-plugin": "^6.19.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
