{
  "name": "evolve-edge",
  "private": true,
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "build": "pnpm --filter @evolve-edge/db prisma:generate && turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "preflight:first-customer:env": "pnpm --filter @evolve-edge/web preflight:first-customer:env",
    "preflight:first-customer": "pnpm --filter @evolve-edge/web preflight:first-customer",
    "db:generate": "pnpm --filter @evolve-edge/db generate",
    "db:migrate:deploy": "pnpm --filter @evolve-edge/db exec prisma migrate deploy --schema prisma/schema.prisma",
    "db:push": "pnpm --filter @evolve-edge/db exec prisma db push --schema prisma/schema.prisma",
    "db:seed": "pnpm --filter @evolve-edge/db exec tsx prisma/seed.ts"
  },
  "devDependencies": {
    "turbo": "^2.9.5",
    "typescript": "^5.8.3"
  }
}
