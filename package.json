{
  "name": "evolve-edge-saas",
  "private": true,
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:generate": "pnpm --filter @evolve-edge/db prisma generate",
    "db:migrate": "pnpm --filter @evolve-edge/db prisma migrate dev",
    "db:push": "pnpm --filter @evolve-edge/db prisma db push"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  }
}

