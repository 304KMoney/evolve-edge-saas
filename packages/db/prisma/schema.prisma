  dedupeKey                  String                     @unique
  primaryContactEmail        String
  normalizedPrimaryContactEmail String
  companyName                String?
  lifecycleStage             CustomerLifecycleStage     @default(LEAD)
  stageSource                CustomerAccountStageSource @default(SYSTEM)
  stageUpdatedAt             DateTime                   @default(now())
  lastSystemSyncedAt         DateTime?
  wonAt                      DateTime?
  briefingScheduledAt        DateTime?
  monitoringActivatedAt      DateTime?
  nextActionLabel            String?
  nextActionDueAt            DateTime?
  nextActionOwner            String?
  founderReviewRequired      Boolean                    @default(false)
  founderReviewReason        String?
  founderReviewRequestedAt   DateTime?
  founderReviewResolvedAt    DateTime?
  crmCompanyId               String?
  crmDealId                  String?
  metadata                   Json?
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  organization               Organization?              @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  primaryLeadSubmission      LeadSubmission?            @relation(fields: [primaryLeadSubmissionId], references: [id], onDelete: SetNull)
  primaryProvisioningRequest ProvisioningRequest?       @relation(fields: [primaryProvisioningRequestId], references: [id], onDelete: SetNull)
  timelineEntries            CustomerAccountTimelineEntry[]
  engagementPrograms         EngagementProgram[]
  operationsQueueItems       OperationsQueueItem[]
  paymentReconciliations     PaymentReconciliationRecord[]
  customerAccessGrants       CustomerAccessGrantRecord[]
  reports                    Report[]                    @relation("CustomerAccountReports")
  operatorWorkflowEvents     OperatorWorkflowEventRecord[]

    @@index([normalizedPrimaryContactEmail, createdAt])
    @@index([lifecycleStage, updatedAt])
    @@index([founderReviewRequired, nextActionDueAt, updatedAt])
    @@index([primaryLeadSubmissionId])
    @@index([primaryProvisioningRequestId])
  }

model CustomerAccountTimelineEntry {
  id                String                           @id @default(cuid())
  customerAccountId String
  organizationId    String?
  actorUserId       String?
  actorType         AuditActorType                  @default(SYSTEM)
  actorLabel        String?
  entryType         CustomerAccountTimelineEntryType
  category          CustomerAccountTimelineCategory @default(SYSTEM)
  visibility        CustomerAccountTimelineVisibility @default(INTERNAL)
  severity          CustomerAccountTimelineSeverity @default(INFO)
  sourceSystem      CustomerAccountTimelineSourceSystem @default(APP)
  eventCode         String?
  eventKey          String?                         @unique
  sourceRecordType  String?
  sourceRecordId    String?
  title             String
  body              String?
  metadata          Json?
  occurredAt        DateTime                        @default(now())
  createdAt         DateTime                        @default(now())
  customerAccount   CustomerAccount                 @relation(fields: [customerAccountId], references: [id], onDelete: Cascade)
  organization      Organization?                   @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actorUser         User?                           @relation("CustomerAccountTimelineActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([customerAccountId, occurredAt])
  @@index([organizationId, occurredAt])
  @@index([entryType, occurredAt])
  @@index([category, occurredAt])
  @@index([visibility, occurredAt])
  @@index([severity, occurredAt])
  @@index([sourceSystem, occurredAt])
}

model OperationsQueueItem {
  id                    String                    @id @default(cuid())
  organizationId        String
  customerAccountId     String?
  assignedUserId        String?
  queueType             OperationsQueueType
  ruleCode              String
  dedupeKey             String                    @unique
  sourceSystem          OperationsQueueSourceSystem @default(APP)
  sourceRecordType      String?
  sourceRecordId        String?
  severity              OperationsQueueSeverity
  status                OperationsQueueStatus     @default(NEW)
  title                 String
  summary               String
  recommendedAction     String?
  reasonLabel           String?
  metadata              Json?
  firstDetectedAt       DateTime                  @default(now())
  lastDetectedAt        DateTime                  @default(now())
  lastEvaluatedAt       DateTime                  @default(now())
  statusUpdatedAt       DateTime                  @default(now())
  assignedAt            DateTime?
  resolvedAt            DateTime?
  dismissedAt           DateTime?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  organization          Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customerAccount       CustomerAccount?          @relation(fields: [customerAccountId], references: [id], onDelete: SetNull)
  assignedUser          User?                     @relation("OperationsQueueAssignedTo", fields: [assignedUserId], references: [id], onDelete: SetNull)
  historyEntries        OperationsQueueHistoryEntry[]

  @@index([organizationId, queueType, status, severity, updatedAt])
  @@index([customerAccountId, queueType, status, updatedAt])
  @@index([assignedUserId, status, updatedAt])
  @@index([queueType, status, severity, updatedAt])
  @@index([sourceRecordType, sourceRecordId])
}

model OperationsQueueHistoryEntry {
  id                   String                          @id @default(cuid())
  operationsQueueItemId String
  organizationId       String
  actorUserId          String?
  actorType            AuditActorType                 @default(SYSTEM)
  actorLabel           String?
  entryType            OperationsQueueHistoryEntryType
  fromStatus           OperationsQueueStatus?
  toStatus             OperationsQueueStatus?
  note                 String?
  metadata             Json?
  createdAt            DateTime                       @default(now())
  operationsQueueItem  OperationsQueueItem            @relation(fields: [operationsQueueItemId], references: [id], onDelete: Cascade)
  organization         Organization                   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorUser            User?                          @relation("OperationsQueueHistoryActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([operationsQueueItemId, createdAt])
  @@index([organizationId, createdAt])
  @@index([entryType, createdAt])
}

model Vendor {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  category       String?
  riskNotes      String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model AIModel {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  provider       String
  usageContext   String?
  riskNotes      String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Notification {
  id             String       @id @default(cuid())
  organizationId String
  type           String
  title          String
  body           String
  actionUrl      String?
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id             String         @id @default(cuid())
  organizationId String?
  userId         String?
  actorType      AuditActorType @default(USER)
  actorLabel     String?
  action         String
  entityType     String
  entityId       String
  resourceType   String?
  resourceId     String?
  dataClassification DataClassification?
  metadata       Json?
  requestContext Json?
  createdAt      DateTime       @default(now())
  organization   Organization?  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?          @relation(fields: [userId], references: [id])

  @@index([organizationId, createdAt])
  @@index([action, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([resourceType, resourceId, createdAt])
}
