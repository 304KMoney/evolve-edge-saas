  @@index([usageMeterId, occurredAt])
  @@index([subscriptionId, occurredAt])
  @@index([sourceRecordType, sourceRecordId])
}

model WorkflowRoutingDecision {
  id                 String                     @id @default(cuid())
  organizationId     String
  actorUserId        String?
  workflowFamily     WorkflowRoutingFamily
  sourceRecordType   String
  sourceRecordId     String
  routeKey           String
  processingTier     String
  disposition        WorkflowRoutingDisposition
  decisionVersion    String
  sourceSystem       String                     @default("app")
  idempotencyKey     String                     @unique
  canonicalPlanKey   CanonicalPlanKey?
  planCode           String?
  subscriptionStatus SubscriptionStatus?
  billingAccessState BillingAccessState?
  workspaceMode      String?
  reasonCodes        Json
  matchedRules       Json?
  entitlementSummary Json
  quotaState         Json
  workflowHints      Json
  metadata           Json?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  organization       Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorUser          User?                      @relation("WorkflowRoutingDecisionActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([workflowFamily, createdAt])
  @@index([sourceRecordType, sourceRecordId, createdAt])
}

/// Canonical backend-owned routing decision. Tenant ownership is explicit here
/// and downstream workflow execution must inherit from this record.
model RoutingSnapshot {
  id                    String                @id @default(cuid())
  organizationId        String
  userId                String?
  billingEventId        String?
  sourceSystem          String
  sourceEventType       String
  sourceEventId         String
  sourceRecordType      String?
  sourceRecordId        String?
  idempotencyKey        String                @unique
  planCode              CommercialPlanCode
  workflowCode          CanonicalWorkflowCode
  entitlementsJson      Json
  normalizedHintsJson   Json
  routingReasonJson     Json
  commercialStateJson   Json?
  status                RoutingSnapshotStatus @default(PENDING)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  organization          Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                  User?                 @relation("RoutingSnapshotUser", fields: [userId], references: [id], onDelete: SetNull)
  billingEvent          BillingEvent?         @relation(fields: [billingEventId], references: [id], onDelete: SetNull)
  workflowDispatches    WorkflowDispatch[]
  deliveryStates        DeliveryStateRecord[]

  @@unique([sourceSystem, sourceEventId])
  @@index([billingEventId, createdAt])
  @@index([organizationId, createdAt])
  @@index([status, createdAt])
  @@index([planCode, workflowCode, createdAt])
}

/// Canonical n8n handoff record. Tenant ownership is intentionally inherited
/// from RoutingSnapshot.organizationId so execution cannot diverge from the
/// persisted backend routing decision.
model WorkflowDispatch {
  id                 String                 @id @default(cuid())
  routingSnapshotId  String
  eventType          String
  destination        String
  idempotencyKey     String                 @unique
  correlationId      String                 @unique
  status             WorkflowDispatchStatus @default(PENDING)
  attemptCount       Int                    @default(0)
  nextRetryAt        DateTime?
  lastAttemptAt      DateTime?
  dispatchedAt       DateTime?
  deliveredAt        DateTime?
  responseStatus     Int?
  lastError          String?
  externalExecutionId String?
  requestPayload     Json
  responsePayload    Json?
  metadata           Json?
  dataClassification DataClassification       @default(NON_SENSITIVE)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  routingSnapshot    RoutingSnapshot        @relation(fields: [routingSnapshotId], references: [id], onDelete: Cascade)
  deliveryStates     DeliveryStateRecord[]

  @@unique([routingSnapshotId, eventType, destination])
  @@index([status, nextRetryAt])
  @@index([routingSnapshotId, createdAt])
  @@index([destination, status, createdAt])
}

/// Canonical paid-request lifecycle record. Tenant ownership is explicit here
/// because operators use this model directly to reason about fulfillment state.
model DeliveryStateRecord {
  id                      String              @id @default(cuid())
  organizationId          String
  userId                  String?
  billingEventId          String?
  routingSnapshotId       String?             @unique
  workflowDispatchId      String?             @unique
  reportId                String?             @unique
  reportPackageId         String?             @unique
  sourceSystem            String
  sourceEventType         String
  sourceEventId           String
  sourceRecordType        String?
  sourceRecordId          String?
  idempotencyKey          String              @unique
  planCode                CommercialPlanCode?
  workflowCode            CanonicalWorkflowCode?
  externalResultReference String?
  entitlementsJson        Json?
  routingHintsJson        Json?
  statusReasonJson        Json?
  latestExecutionResultJson Json?
  lastError               String?
  status                  DeliveryStateStatus @default(PAID)
  paidAt                  DateTime?
  routedAt                DateTime?
  processingAt            DateTime?
  awaitingReviewAt        DateTime?
  reportGeneratedAt       DateTime?
  deliveredAt             DateTime?
  failedAt                DateTime?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  organization            Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                    User?               @relation("DeliveryStateUser", fields: [userId], references: [id], onDelete: SetNull)
  billingEvent            BillingEvent?       @relation(fields: [billingEventId], references: [id], onDelete: SetNull)
  routingSnapshot         RoutingSnapshot?    @relation(fields: [routingSnapshotId], references: [id], onDelete: SetNull)
  workflowDispatch        WorkflowDispatch?   @relation(fields: [workflowDispatchId], references: [id], onDelete: SetNull)
  report                  Report?             @relation(fields: [reportId], references: [id], onDelete: SetNull)
  reportPackage           ReportPackage?      @relation(fields: [reportPackageId], references: [id], onDelete: SetNull)
  transitions             DeliveryStateTransition[]

  @@unique([sourceSystem, sourceEventId])
  @@index([organizationId, status, updatedAt])
  @@index([organizationId, createdAt])
  @@index([billingEventId, createdAt])
  @@index([externalResultReference, createdAt])
}

model DeliveryStateTransition {
  id                    String              @id @default(cuid())
  deliveryStateRecordId String
  organizationId        String
  actorUserId           String?
  actorType             AuditActorType      @default(SYSTEM)
  actorLabel            String?
  fromStatus            DeliveryStateStatus?
  toStatus              DeliveryStateStatus
  reasonCode            String?
  note                  String?
  metadata              Json?
  occurredAt            DateTime            @default(now())
  createdAt             DateTime            @default(now())
  deliveryStateRecord   DeliveryStateRecord @relation(fields: [deliveryStateRecordId], references: [id], onDelete: Cascade)
  organization          Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorUser             User?               @relation("DeliveryStateTransitionActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([deliveryStateRecordId, occurredAt])
  @@index([organizationId, occurredAt])
  @@index([toStatus, occurredAt])
}

// Provisioning requests are the controlled inbound handoff record for
// sales/ops automation. externalReferenceId + sourceSystem provides idempotency
// so repeated calls from n8n/HubSpot cannot create duplicate workspaces.
model ProvisioningRequest {
  id                  String             @id @default(cuid())
  sourceSystem        String
  externalReferenceId String
  organizationId      String?
  primaryContactEmail String
  planCode            String?
  crmAccountId        String?
  crmDealId           String?
  status              ProvisioningStatus @default(PENDING)
  payload             Json
  processedAt         DateTime?
  failedAt            DateTime?
  lastError           String?
  ownerUserId         String?
  ownerInviteId       String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  organization        Organization?      @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  customerAccounts    CustomerAccount[]

  @@unique([sourceSystem, externalReferenceId])
  @@index([status, createdAt])
  @@index([organizationId, createdAt])
}

