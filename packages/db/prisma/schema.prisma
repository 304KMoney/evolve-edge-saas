model User {
  id                      String                     @id @default(cuid())
  email                   String                     @unique
  firstName               String?
  lastName                String?
  platformRole            PlatformUserRole           @default(NONE)
  authProviderId          String?                    @unique
  hubspotContactId        String?                    @unique
  onboardingCompletedAt   DateTime?
  createdAt               DateTime                   @default(now())
  updatedAt               DateTime                   @updatedAt
  passwordCredential      PasswordCredential?
  sessions                Session[]
  memberships             OrganizationMember[]
  createdOrganizations    Organization[]             @relation("OrganizationCreatedBy")
  organizationInvitesSent OrganizationInvite[]       @relation("OrganizationInviteInvitedBy")
  createdAssessments      Assessment[]               @relation("AssessmentCreatedBy")
  createdReports          Report[]                   @relation("ReportCreatedBy")
  deliveredReports        Report[]                   @relation("ReportDeliveredBy")
  viewedReports           Report[]                   @relation("ReportViewedBy")
  auditLogs               AuditLog[]
  leadSubmissions         LeadSubmission[]
  productAnalyticsEvents  ProductAnalyticsEvent[]
  emailNotifications      EmailNotification[]
  customerRuns            CustomerRun[]              @relation("CustomerRunInitiatedBy")
  customerAccountTimelineEntries CustomerAccountTimelineEntry[] @relation("CustomerAccountTimelineActor")
  createdReportPackageVersions ReportPackageVersion[] @relation("ReportPackageVersionCreatedBy")
  qaReviewedReportPackages ReportPackage[] @relation("ReportPackageQaReviewedBy")
  founderReviewedReportPackages ReportPackage[] @relation("ReportPackageFounderReviewedBy")
  sentReportPackages ReportPackage[] @relation("ReportPackageSentBy")
  briefingBookedReportPackages ReportPackage[] @relation("ReportPackageBriefingBookedBy")
  briefingCompletedReportPackages ReportPackage[] @relation("ReportPackageBriefingCompletedBy")
  uploadedEvidenceFiles EvidenceFile[] @relation("EvidenceUploadedBy")
  reviewedEvidenceFiles EvidenceFile[] @relation("EvidenceReviewedBy")
  createdEvidenceVersions EvidenceFileVersion[] @relation("EvidenceVersionCreatedBy")
  evidenceAnnotations EvidenceAnnotation[] @relation("EvidenceAnnotationAuthor")
  reviewedControlAssessments ControlAssessment[] @relation("ControlAssessmentReviewedBy")
  eventReplayAttempts EventReplayAttempt[] @relation("EventReplayRequestedBy")
  assignedOperationsQueueItems OperationsQueueItem[] @relation("OperationsQueueAssignedTo")
  operationsQueueHistoryEntries OperationsQueueHistoryEntry[] @relation("OperationsQueueHistoryActor")
  billingCustomers       BillingCustomer[]          @relation("BillingCustomerOwner")
  ownedBillingOrganizations Organization[]          @relation("OrganizationBillingOwner")
  recordedBillingEventLogs BillingEventLog[]        @relation("BillingEventLogRecordedBy")
  createdEntitlementOverrides EntitlementOverride[] @relation("EntitlementOverrideCreatedBy")
  workflowRoutingDecisions WorkflowRoutingDecision[] @relation("WorkflowRoutingDecisionActor")
  routingSnapshots       RoutingSnapshot[]          @relation("RoutingSnapshotUser")
  deliveryStates         DeliveryStateRecord[]      @relation("DeliveryStateUser")
  deliveryStateTransitions DeliveryStateTransition[] @relation("DeliveryStateTransitionActor")
  customerAccessGrants   CustomerAccessGrantRecord[] @relation("CustomerAccessGrantUser")
}

model Organization {
  id                  String                  @id @default(cuid())
  name                String
  slug                String                  @unique
  hubspotCompanyId    String?                 @unique
  createdByUserId     String?
  billingOwnerUserId  String?
  industry            String?
  sizeBand            String?
  country             String?
  regulatoryProfile   Json?
  aiUsageSummary      String?
  currentPostureScore Int?
  dataClassification  DataClassification      @default(SENSITIVE)
  onboardingCompletedAt DateTime?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  createdBy           User?                   @relation("OrganizationCreatedBy", fields: [createdByUserId], references: [id])
  billingOwner        User?                   @relation("OrganizationBillingOwner", fields: [billingOwnerUserId], references: [id], onDelete: SetNull)
  members             OrganizationMember[]
  invites             OrganizationInvite[]
  subscriptions       Subscription[]
  billingCustomers    BillingCustomer[]
  billingEventLogs    BillingEventLog[]
  entitlementOverrides EntitlementOverride[]
  usageMeters         UsageMeter[]
  usageEvents         UsageEvent[]
  assessments         Assessment[]
  reports             Report[]
  frameworkSelections OrganizationFramework[]
  vendors             Vendor[]
  models              AIModel[]
  notifications       Notification[]
  auditLogs           AuditLog[]
  provisioningRequests ProvisioningRequest[]
  leadSubmissions     LeadSubmission[]
  productAnalyticsEvents ProductAnalyticsEvent[]
  emailNotifications  EmailNotification[]
  customerRuns        CustomerRun[]
  customerAccount     CustomerAccount?
  customerAccountTimelineEntries CustomerAccountTimelineEntry[]
  paymentReconciliations PaymentReconciliationRecord[]
  customerAccessGrants CustomerAccessGrantRecord[]
  operatorWorkflowEvents OperatorWorkflowEventRecord[]
  reportPackages      ReportPackage[]
  monitoringSubscription MonitoringSubscription?
  monitoringFindings  MonitoringFinding[]
  monitoringFrameworks MonitoringFramework[]
  monitoringRiskSnapshots MonitoringRiskSnapshot[]
  monitoringChecks    MonitoringCheck[]
  engagementPrograms  EngagementProgram[]
  engagementDeliverables EngagementDeliverable[]
  engagementOpportunities EngagementOpportunity[]
  evidenceFiles       EvidenceFile[]
  evidenceAnnotations EvidenceAnnotation[]
  evidenceVersions    EvidenceFileVersion[]
  controlAssessments  ControlAssessment[]
  controlAssessmentSnapshots ControlAssessmentSnapshot[]
  findingControlMappings FindingControlMapping[]
  evidenceControlMappings EvidenceControlMapping[]
  recommendationControlMappings RecommendationControlMapping[]
  frameworkPostureSnapshots FrameworkPostureSnapshot[]
  eventReplayAttempts  EventReplayAttempt[]
  operationsQueueItems OperationsQueueItem[]
  operationsQueueHistoryEntries OperationsQueueHistoryEntry[]
  workflowRoutingDecisions WorkflowRoutingDecision[]
  routingSnapshots      RoutingSnapshot[]
  deliveryStates        DeliveryStateRecord[]
  deliveryStateTransitions DeliveryStateTransition[]
  aiWorkflowFeedbackEntries AiWorkflowFeedback[]
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           UserRole
  isBillingAdmin Boolean      @default(false)
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

model OrganizationInvite {
  id              String       @id @default(cuid())
  organizationId  String
  email           String
  role            UserRole
  isBillingAdmin  Boolean      @default(false)
  status          InviteStatus @default(PENDING)
  tokenHash       String       @unique
  invitedByUserId String?
  expiresAt       DateTime
  acceptedAt      DateTime?
  createdAt       DateTime     @default(now())
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy       User?        @relation("OrganizationInviteInvitedBy", fields: [invitedByUserId], references: [id])

  @@index([organizationId, email])
}

model PasswordCredential {
  userId               String   @id
  passwordHash         String
  passwordUpdatedAt    DateTime @default(now())
  failedLoginAttempts  Int      @default(0)
  lockedUntil          DateTime?
  lastAuthenticatedAt  DateTime?
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  userId     String
  expiresAt  DateTime
  lastSeenAt DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Plan {
  id                     String         @id @default(cuid())
  code                   String         @unique
  canonicalKey           CanonicalPlanKey
  name                   String
  family                 String         @default("growth")
  version                Int            @default(1)
  description            String?
  currency               String         @default("USD")
  billingIntervalMode    BillingInterval @default(ANNUAL)
  billingInterval        String
  priceCents             Int
  trialDays              Int            @default(14)
  sortOrder              Int            @default(0)
  isActive               Boolean        @default(true)
  isPublic               Boolean        @default(true)
  billingProvider        BillingProvider @default(STRIPE)
  billingLookupKey       String?        @unique
  stripePriceId          String?        @unique
  activeAssessmentsLimit Int
  seatsLimit             Int
  frameworksLimit        Int
  features               Json
  entitlementConfig      Json?
  adminMetadata          Json?
  subscriptions          Subscription[]
  billingEventLogs       BillingEventLog[]

  @@index([canonicalKey, isActive, sortOrder])
  @@index([family, isActive, sortOrder])
}

model Subscription {
  id                   String             @id @default(cuid())
  organizationId       String
  planId               String
  billingCustomerId    String?
  accessState          BillingAccessState @default(INCOMPLETE)
  billingProvider      BillingProvider    @default(STRIPE)
  externalStatus       String?
  canonicalPlanKeySnapshot CanonicalPlanKey?
  planCodeSnapshot     String?
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceIdSnapshot String?
  status               SubscriptionStatus
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  accessEndsAt         DateTime?
  gracePeriodEndsAt    DateTime?
  trialStartedAt       DateTime?
  trialEndsAt          DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  cancelScheduledAt    DateTime?
  canceledAt           DateTime?
  endedAt              DateTime?
  reactivatedAt        DateTime?
  statusUpdatedAt      DateTime           @default(now())
  latestInvoiceId      String?
  latestInvoiceStatus  String?
  lastInvoicePaidAt    DateTime?
  lastPaymentFailedAt  DateTime?
  lastPaymentFailureMessage String?
  billingMetadata      Json?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  organization         Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan                 Plan               @relation(fields: [planId], references: [id])
  billingCustomer      BillingCustomer?   @relation(fields: [billingCustomerId], references: [id], onDelete: SetNull)
  engagementPrograms   EngagementProgram[]
  billingEventLogs     BillingEventLog[]
  usageMeters          UsageMeter[]
  usageEvents          UsageEvent[]

  @@index([organizationId, accessState, updatedAt])
  @@index([organizationId, status, updatedAt])
  @@index([billingCustomerId, updatedAt])
}

/// Canonical Stripe receipt record. This model is intentionally not directly
/// tenant-owned because some verified payment events can arrive before the app
/// resolves a workspace. Tenant linkage must be established through downstream
/// canonical records such as RoutingSnapshot, DeliveryStateRecord, or an
/// organization-scoped billing projection.
model BillingEvent {
  id                String             @id @default(cuid())
  stripeEventId     String             @unique
  type              String
  status            BillingEventStatus @default(PENDING)
  processingStartedAt DateTime?
  processedAt       DateTime?
  failedAt          DateTime?
  lastError         String?
  payload           Json
  createdAt         DateTime           @default(now())
  replayAttempts    EventReplayAttempt[]
  routingSnapshots  RoutingSnapshot[]
  deliveryStates    DeliveryStateRecord[]
  paymentReconciliations PaymentReconciliationRecord[]

  @@index([status, createdAt])
}

/// Canonical Stripe payment reconciliation record. This model persists the
/// backend-owned reconciliation outcome derived from a verified billing event so
/// access issuance and operator review can rely on app state instead of raw
/// webhook payloads.
model PaymentReconciliationRecord {
  id                    String                      @id @default(cuid())
  billingEventId        String?                     @unique
  stripeEventId         String                      @unique
  stripeEventType       String
  checkoutSessionId     String?
  stripePaymentReference String?
  customerEmail         String?
  selectedPlan          CommercialPlanCode?
  reconciliationStatus  PaymentReconciliationStatus @default(VERIFIED)
  correlationId         String?
  organizationId        String?
  customerAccountId     String?
  reportId              String?
  metadata              Json?
  lastError             String?
  reconciledAt          DateTime?
  failedAt              DateTime?
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt
  billingEvent          BillingEvent?               @relation(fields: [billingEventId], references: [id], onDelete: SetNull)
  organization          Organization?               @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  customerAccount       CustomerAccount?            @relation(fields: [customerAccountId], references: [id], onDelete: SetNull)
  report                Report?                     @relation(fields: [reportId], references: [id], onDelete: SetNull)
  accessGrants          CustomerAccessGrantRecord[]
  operatorWorkflowEvents OperatorWorkflowEventRecord[]

  @@index([reconciliationStatus, createdAt])
  @@index([checkoutSessionId, createdAt])
  @@index([stripePaymentReference, createdAt])
  @@index([organizationId, createdAt])
  @@index([customerEmail, createdAt])
  @@index([customerAccountId, createdAt])
  @@index([correlationId, createdAt])
}

/// Canonical customer report-access grant. This model is intentionally narrow:
/// it stores the app-owned access decision emitted from payment reconciliation
/// without becoming a full identity or entitlement platform.
model CustomerAccessGrantRecord {
  id                      String                       @id @default(cuid())
  paymentReconciliationId String?                      @unique
  userId                  String?
  customerEmail           String?
  organizationId          String?
  customerAccountId       String?
  selectedPlan            CommercialPlanCode?
  scopeType               CustomerAccessGrantScopeType
  reportId                String?
  grantStatus             CustomerAccessGrantStatus   @default(ISSUED)
  issuedAt                DateTime                    @default(now())
  expiresAt               DateTime?
  revokedAt               DateTime?
  metadata                Json?
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt
  paymentReconciliation   PaymentReconciliationRecord? @relation(fields: [paymentReconciliationId], references: [id], onDelete: SetNull)
  user                    User?                       @relation("CustomerAccessGrantUser", fields: [userId], references: [id], onDelete: SetNull)
  organization            Organization?               @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  customerAccount         CustomerAccount?            @relation(fields: [customerAccountId], references: [id], onDelete: SetNull)
  report                  Report?                     @relation(fields: [reportId], references: [id], onDelete: SetNull)

  @@index([paymentReconciliationId, createdAt])
  @@index([grantStatus, createdAt])
  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([customerEmail, createdAt])
  @@index([customerAccountId, createdAt])
  @@index([reportId, createdAt])
  @@index([expiresAt, createdAt])
}

/// Minimal operator-facing workflow event record for first-customer operations.
/// This is an auditable progress/event stream, not a full admin workflow
/// product. Use it to surface the key lifecycle moments operators need to
/// understand payment, access, and delivery state.
model OperatorWorkflowEventRecord {
  id                      String                         @id @default(cuid())
  eventKey                String?                        @unique
  organizationId          String?
  customerAccountId       String?
  reportId                String?
  paymentReconciliationId String?
  eventCode               OperatorWorkflowEventCode
  severity                CustomerAccountTimelineSeverity @default(INFO)
  message                 String
  metadata                Json?
  createdAt               DateTime                       @default(now())
  organization            Organization?                  @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  customerAccount         CustomerAccount?               @relation(fields: [customerAccountId], references: [id], onDelete: SetNull)
  report                  Report?                        @relation(fields: [reportId], references: [id], onDelete: SetNull)
  paymentReconciliation   PaymentReconciliationRecord?   @relation(fields: [paymentReconciliationId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([customerAccountId, createdAt])
  @@index([reportId, createdAt])
  @@index([paymentReconciliationId, createdAt])
  @@index([eventCode, createdAt])
  @@index([severity, createdAt])
}

/// Durable inbound n8n writeback receipt used to prevent duplicate report
/// writeback side effects from repeated callbacks with the same correlation,
/// report target, and milestone marker.
model WorkflowWritebackReceipt {
  id           String   @id @default(cuid())
  dedupeKey    String   @unique
  correlationId String
  dispatchId   String
  reportId     String
  statusMarker String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

