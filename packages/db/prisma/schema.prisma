// Domain events are the durable integration backbone for downstream workflows.
// Events are persisted first with PENDING status, deduplicated by idempotencyKey,
// and can later be replayed or dispatched by external automation safely.
/// Durable integration event record. `orgId` is the legacy field name here,
/// but it carries the canonical organization/tenant identifier for downstream
/// projection and replay flows.
model DomainEvent {
  id             String            @id @default(cuid())
  type           String
  aggregateType  String
  aggregateId    String
  orgId          String?
  userId         String?
  idempotencyKey String            @unique
  occurredAt     DateTime
  payload        Json
  status         DomainEventStatus @default(PENDING)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([type, occurredAt])
  @@index([orgId, occurredAt])
  @@index([status, occurredAt])
  deliveries     WebhookDelivery[]
  emailNotifications EmailNotification[]
  replayAttempts EventReplayAttempt[]
}

/// Durable outbound delivery attempt for a DomainEvent. Tenant ownership is
/// inherited from the parent DomainEvent.orgId.
model WebhookDelivery {
  id             String                @id @default(cuid())
  eventId        String
  destination    String
  status         WebhookDeliveryStatus @default(PENDING)
  attemptCount   Int                   @default(0)
  nextRetryAt    DateTime?
  lastAttemptAt  DateTime?
  deliveredAt    DateTime?
  responseStatus Int?
  lastError      String?
  requestUrl     String
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  event          DomainEvent           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  replayAttempts EventReplayAttempt[]

  @@unique([eventId, destination])
  @@index([status, nextRetryAt])
  @@index([destination, status])
}

model EventReplayAttempt {
  id                String                   @id @default(cuid())
  targetType        EventReplayTargetType
  targetId          String
  organizationId    String?
  billingEventId    String?
  domainEventId     String?
  webhookDeliveryId String?
  requestedByUserId String?
  requestedByEmail  String
  reason            String
  notes             String?
  correlationId     String                   @unique
  status            EventReplayAttemptStatus @default(REQUESTED)
  failureCode       String?
  failureReason     String?
  metadata          Json?
  createdAt         DateTime                 @default(now())
  completedAt       DateTime?
  organization      Organization?            @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  billingEvent      BillingEvent?            @relation(fields: [billingEventId], references: [id], onDelete: SetNull)
  domainEvent       DomainEvent?             @relation(fields: [domainEventId], references: [id], onDelete: SetNull)
  webhookDelivery   WebhookDelivery?         @relation(fields: [webhookDeliveryId], references: [id], onDelete: SetNull)
  requestedByUser   User?                    @relation("EventReplayRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)

  @@index([targetType, targetId, createdAt])
  @@index([organizationId, createdAt])
  @@index([status, createdAt])
}

model EmailNotification {
  id                String                  @id @default(cuid())
  templateKey       String
