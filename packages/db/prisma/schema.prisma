  @@index([eventType, occurredAt])
  @@index([canonicalPlanKey, occurredAt])
  @@index([planCodeSnapshot, occurredAt])
  @@index([stripeEventId])
  @@index([stripeCheckoutSessionId])
  @@index([stripePaymentIntentId])
